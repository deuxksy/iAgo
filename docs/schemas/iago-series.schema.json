{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://iago.local/schemas/iago-series.schema.json",
  "title": "iAgo Series",
  "description": "iAgo에서 시리즈(권 묶음)를 표현하는 스키마. 서로 다른 권을 안정적으로 묶고 정렬(권 번호)을 재현 가능하게 만든다.",
  "type": ["object", "null"],
  "required": ["key", "source", "source_id", "members"],
  "additionalProperties": false,
  "properties": {
    "key": {
      "type": "string",
      "description": "출처 네임스페이스가 포함된 시리즈 전역 키. 예: aladin_bookid:52796225"
    },
    "source": {
      "type": "string",
      "enum": ["aladin"],
      "description": "시리즈 원천 데이터 출처"
    },
    "source_id": {
      "type": "string",
      "description": "출처별 시리즈 식별자. 알라딘은 bookid를 문자열로 저장."
    },
    "title": {
      "type": ["string", "null"],
      "description": "표시용 시리즈명(없으면 null)"
    },
    "size": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "총 권수(알 수 있을 때만)"
    },
    "version": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "멤버 목록 변경 시 증가시키는 버전(선택)"
    },
    "updated_at": {
      "type": ["string", "null"],
      "description": "마지막 확인 시각(ISO8601)"
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/SeriesMember" }
    }
  },
  "definitions": {
    "SeriesMember": {
      "type": "object",
      "required": ["index", "ids"],
      "additionalProperties": false,
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1,
          "description": "시리즈 내 권 번호(1-base)"
        },
        "title": {
          "type": ["string", "null"],
          "description": "표시용 권 제목(선택)"
        },
        "ids": {
          "type": "object",
          "required": ["aladin_item_id"],
          "additionalProperties": false,
          "properties": {
            "aladin_item_id": { "type": "integer" },
            "isbn13": { "type": ["string", "null"] }
          }
        }
      }
    }
  },
  "examples": [
    {
      "key": "aladin_bookid:52796225",
      "source": "aladin",
      "source_id": "52796225",
      "title": "타워 던전",
      "size": 4,
      "updated_at": "2026-03-09T00:00:00Z",
      "members": [
        { "index": 1, "title": "타워 던전 1", "ids": { "aladin_item_id": 365659712, "isbn13": "9791141158439" } },
        { "index": 2, "title": "타워 던전 2", "ids": { "aladin_item_id": 369308582, "isbn13": "9791141161774" } },
        { "index": 3, "title": "타워 던전 3", "ids": { "aladin_item_id": 373365108, "isbn13": "9791141166571" } },
        { "index": 4, "title": "타워 던전 4", "ids": { "aladin_item_id": 387582084, "isbn13": "9791141173562" } }
      ]
    }
  ]
}
